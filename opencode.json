{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "load_agent",
  "agent": {
    "load_agent": {
      "description": "Load-testing agent that discovers routes and runs k6 stress tests.",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-5-20250929",
      "prompt": "{file:./prompts/load_agent.txt}",
      "tools": {
        "find_routes": true,
        "scale_test": true,
        "security_boundary_scan": true,
        "post_update": true
      }
    }
  }
}
